{
  "name": "discord-ai-agent",
  "version": "0.1.0",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Slokh/discord-ai-agent.git"
  },
  "bugs": {
    "url": "https://github.com/Slokh/discord-ai-agent/issues"
  },
  "private": true,
  "type": "module",
  "description": "Self-hosted Discord AI agent with permission-aware memory, model-led tools, and sandboxed code-update PRs.",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "api": "tsx watch src/index.ts api",
    "bot": "tsx watch src/index.ts bot",
    "worker": "tsx watch src/index.ts worker",
    "start": "node dist/src/index.js",
    "start:api": "node dist/src/index.js api",
    "start:bot": "node dist/src/index.js bot",
    "start:worker": "node dist/src/index.js worker",
    "start:all": "node dist/src/index.js all",
    "build": "npm run console:build && tsc -p tsconfig.json",
    "console:dev": "vite --config vite.console.config.ts --mode fixture",
    "console:dev:live": "tsx scripts/consoleDevLive.ts",
    "console:build": "vite build --config vite.console.config.ts",
    "console:preview": "vite preview --config vite.console.config.ts",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:db": "DISCORD_AI_AGENT_DB_TESTS=true vitest run tests/integration/repository-db.test.ts tests/integration/jobs-db.test.ts",
    "test:watch": "vitest",
    "lint": "eslint .",
    "verify": "npm run lint && npm run typecheck && npm test && npm audit --omit=dev",
    "verify:db": "npm run migrate && npm run test:db",
    "migrate": "tsx src/db/migrate.ts",
    "verify:rng": "tsx scripts/verify-rng.ts",
    "crawl": "tsx scripts/crawl.ts",
    "reindex": "tsx scripts/crawl.ts --reindex",
    "aliases": "tsx scripts/userAliases.ts",
    "skills": "tsx scripts/skills.ts",
    "blocked-users": "tsx scripts/blockedUsers.ts",
    "embeddings:backfill": "tsx scripts/backfillEmbeddings.ts",
    "embeddings:worker": "tsx scripts/embeddingWorker.ts",
    "embeddings:reprioritize": "tsx scripts/reprioritizeEmbeddingQueue.ts",
    "doctor": "tsx scripts/doctor.ts",
    "prompt": "tsx scripts/prompt.ts",
    "eval": "tsx scripts/eval.ts",
    "runs:inspect": "tsx scripts/inspectRun.ts",
    "tasks:status": "tsx scripts/agentTaskStatus.ts",
    "invite-url": "tsx scripts/discordInviteUrl.ts",
    "preflight": "tsx scripts/preflight.ts",
    "preflight:deploy": "tsx scripts/deployPreflight.ts",
    "sandbox-cache:status": "tsx scripts/sandboxCache.ts status",
    "sandbox-cache:prune": "tsx scripts/sandboxCache.ts prune",
    "sandbox-cache:clear": "tsx scripts/sandboxCache.ts clear --yes",
    "smoke:discord": "tsx scripts/smokeDiscord.ts",
    "smoke:github": "tsx scripts/smokeGithub.ts",
    "smoke:codegen": "tsx scripts/smokeCodegen.ts",
    "smoke:openrouter": "tsx scripts/smokeOpenRouter.ts",
    "smoke:startup": "tsx scripts/smokeStartup.ts",
    "scan:release": "tsx scripts/scanRelease.ts",
    "clear-commands": "tsx src/discord/registerCommands.ts",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@kubernetes/client-node": "^1.4.0",
    "@octokit/rest": "^21.1.1",
    "discord.js": "^14.19.3",
    "dotenv": "^17.4.2",
    "lucide-react": "^1.24.0",
    "pg": "^8.16.3",
    "pg-boss": "^12.25.1",
    "pino": "^9.7.0",
    "pino-pretty": "^13.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "regen-ui": "^0.5.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.31.0",
    "@playwright/test": "^1.61.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^22.16.5",
    "@types/pg": "^8.15.4",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.2",
    "@vitest/coverage-v8": "^4.1.10",
    "eslint": "^10.6.0",
    "jsdom": "^29.1.1",
    "tsx": "^4.23.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.63.0",
    "vite": "^7.3.6",
    "vitest": "^4.1.10"
  },
  "overrides": {
    "undici": "6.27.0",
    "@base-ui/react": "~1.4.0"
  }
}
