# ── Required ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=
OPENROUTER_API_KEY=
# Postgres with pgvector. The default matches `docker compose up -d postgres`
# (localhost:5433 outside Docker, postgres:5432 inside).
DATABASE_URL=postgres://discord_ai_agent:discord_ai_agent@localhost:5433/discord_ai_agent

# ── Code-update PRs (optional feature; leave unset to disable) ───────────────
# All three of repository + a GitHub credential + signing secret are required
# before the bot offers code-update tasks.
GITHUB_REPOSITORY=owner/repo
# Local/dev credential: a fine-grained PAT limited to GITHUB_REPOSITORY.
GITHUB_TOKEN=
# Production credential, preferred over GITHUB_TOKEN.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
# Signs sandbox callback tokens. Generate with: openssl rand -hex 32
TASK_SIGNING_SECRET=
GITHUB_BASE_BRANCH=main
# `local-process` (default) runs code-update tasks in a worker child process.
# `kubernetes-job` runs each task in an isolated Kubernetes Job (advanced).
CODEGEN_EXECUTION_BACKEND=local-process
# Coding harness for code-update tasks: `opencode` (default) or `codex`.
CODEGEN_HARNESS=opencode
# Model used by the coding harness; defaults to OPENROUTER_CHAT_MODEL.
# OPENROUTER_CODEGEN_MODEL=

# ── Bot identity and behavior ────────────────────────────────────────────────
BOT_NAME=ai
DISCORD_LOADING_REACTION=⏳
# `bot`, `worker`, `api`, or `all`. `npm run dev` runs the role set here;
# use `all` for a single-process setup.
DISCORD_AI_AGENT_PROCESS_ROLE=bot
RUN_MIGRATIONS=true
# LOG_LEVEL=info
# NODE_ENV=development
# Deployed commit/image identifier included in runtime and model-call telemetry.
# APP_REVISION=local

# ── Models ───────────────────────────────────────────────────────────────────
OPENROUTER_CHAT_MODEL=z-ai/glm-5.2
# Cheap model for nested summarization/classification calls; defaults to OPENROUTER_CHAT_MODEL.
# OPENROUTER_UTILITY_MODEL=openai/gpt-4o-mini
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image
# OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
# OPENROUTER_APP_TITLE=Discord AI Agent
# OPENROUTER_HTTP_REFERER=http://localhost
# Fixed by the current Postgres vector column and HNSW expression index.
# EMBEDDING_DIMENSIONS=1536

# ── Cost and abuse controls ──────────────────────────────────────────────────
# Daily limits. Set any numeric limit to -1 for unlimited.
# The owner/ops allowlist can override the per-user turn limit for specific
# users at runtime via the setUserTurnLimit tool ("@ai limit @user to 5 posts per day").
BUDGET_USER_TURNS_PER_DAY=50
BUDGET_USER_IMAGES_PER_DAY=10
BUDGET_USER_CODEGEN_PER_DAY=1
BUDGET_GUILD_DAILY_USD=10
# Allowlists are comma-separated Discord user IDs. If BOT_OWNER_USER_ID is set
# and an allowlist is empty, restricted tools default to owner-only; with no
# owner, they are open.
BOT_OWNER_USER_ID=
CODEGEN_ALLOWLIST_USER_IDS=
OPS_ALLOWLIST_USER_IDS=
IMAGE_TOOLS_ALLOWLIST_ONLY=false

# ── Timeouts ─────────────────────────────────────────────────────────────────
DISCORD_AGENT_RESPONSE_TIMEOUT_MS=1800000
# Parallel prompt capacity across different Discord thread keys. A single
# thread key is always serialized to preserve conversation ordering.
AGENT_PROMPT_MAX_CONCURRENCY=4
# Chat turn timeouts: silence abort resets on model/tool/status progress; hard abort is wall-clock.
CHAT_SILENCE_TIMEOUT_MS=120000
CHAT_HARD_TIMEOUT_MS=600000

# ── Memory, retention, and retrieval tuning ──────────────────────────────────
RETENTION_EVENTS_DAYS=60
RETENTION_AUDIT_DAYS=90
RETENTION_EMBEDDING_RUNS_DAYS=14
# Terminal runtime sessions, executions, messages, and artifacts.
RETENTION_RUNTIME_DAYS=90
MEMORY_COMPACTION_THRESHOLD=100
MEMORY_COMPACTION_KEEP_RECENT=30
# MAX_HISTORY_RESULTS=10
# MAX_THREAD_SUMMARY_MESSAGES=80
# MAX_REPLY_CHARS=1800
# CRAWL_BATCH_SIZE=100
# CRAWL_FETCH_RETRIES=3
# CRAWL_RETRY_BASE_MS=1000
# CRAWL_RETRY_MAX_MS=30000
# Cron for the daily reconciliation crawl that backfills any missed messages
# (for example after downtime). Set to an empty string to disable.
# CRAWL_SCHEDULE_CRON=0 6 * * *

# ── Worker queue toggles (split queues across deployments) ───────────────────
# WORKER_CRAWL_ENABLED=true
# WORKER_EMBEDDING_ENABLED=true
# WORKER_TASK_ENABLED=true
# WORKER_DISCORD_AGENT_ENABLED=true

# ── Optional integrations ────────────────────────────────────────────────────
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
# Spotify market (default US).
# SPOTIFY_MARKET=US

# Application-controlled bot and per-user wallets. Privy credentials are
# required whenever WALLET_ENABLED is true. The bot wallet pays network fees
# for user transfers and acts as the treasury for grants and game settlements.
WALLET_ENABLED=false
USER_WALLETS_ENABLED=false
# Opt in only when Discord identity-to-wallet balances should be visible to every member.
WALLET_BALANCES_PUBLIC=false
PRIVY_APP_ID=
PRIVY_APP_SECRET=
# Start on Moderato. Change to mainnet only after validating provisioning,
# grants, transfers, wager settlement, and reconciliation in the payments console.
TEMPO_NETWORK=moderato
# One USD rail is used for balances, transfers, grants, games, and bot funding.
# Discord renders this simply as $ or USD.
TEMPO_USD_TOKEN=USDC.e
WALLET_INITIAL_GRANT_USD=1.00
WALLET_MAX_GAME_SETTLEMENT_USD=10.00
# Untracked persona/prompt overlay file merged into the system prompt when present.
PROMPT_OVERLAY_PATH=.discord-ai-agent/prompt-overlay.md
# Deterministic per-turn toolset scoping to reduce model prompt tokens.
TOOLSET_SCOPING=true

# ── Control plane and run console ────────────────────────────────────────────
# Password for the authenticated run-console UI served by the api role.
CONTROL_UI_AUTH_PASSWORD=
# Public console origin, e.g. https://tasks.example.com. When set, Discord
# replies include a trace footer and code-update progress includes a console link.
CONTROL_UI_PUBLIC_URL=
CONTROL_PLANE_INTERNAL_URL=http://discord-ai-agent-api:8080
# INTERNAL_API_HOST=0.0.0.0
# INTERNAL_API_PORT=8080

# ── Sandbox tuning (code-update tasks) ───────────────────────────────────────
# Shared by both codegen backends.
SANDBOX_CACHE_DIR=/var/cache/discord-ai-agent
# SANDBOX_TASK_TIMEOUT_SECONDS=1800
# Warm-slot lease tuning for the local-process backend / dedicated codegen worker.
# CODEGEN_LEASE_HEARTBEAT_SECONDS=15
# CODEGEN_LEASE_STALE_SECONDS=120
# CODEGEN_LEASE_ACQUIRE_TIMEOUT_SECONDS=1800
# CODEGEN_LEASE_ACQUIRE_POLL_SECONDS=5

# ── Kubernetes backend (advanced; only with CODEGEN_EXECUTION_BACKEND=kubernetes-job)
KUBERNETES_NAMESPACE=discord-ai-agent
SANDBOX_IMAGE=discord-ai-agent-sandbox:latest
# Set when a shared sandbox cache PVC is mounted at SANDBOX_CACHE_DIR.
SANDBOX_CACHE_PVC_NAME=
# SANDBOX_IMAGE_PULL_POLICY=IfNotPresent
# SANDBOX_SERVICE_ACCOUNT_NAME=discord-ai-agent-sandbox
# SANDBOX_CPU_REQUEST=500m
# SANDBOX_CPU_LIMIT=2
# SANDBOX_MEMORY_REQUEST=512Mi
# SANDBOX_MEMORY_LIMIT=2Gi
# SANDBOX_TTL_SECONDS_AFTER_FINISHED=3600
