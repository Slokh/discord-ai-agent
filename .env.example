# Required for the Discord bot.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Required for model calls.
OPENROUTER_API_KEY=

# Required for sandbox task callbacks and code-update PRs.
TASK_SIGNING_SECRET=
GITHUB_TOKEN=
# Preferred in production instead of GITHUB_TOKEN.
GITHUB_APP_ID=
GITHUB_APP_PRIVATE_KEY=
GITHUB_APP_INSTALLATION_ID=
GITHUB_REPOSITORY=owner/repo

# Optional.
BOT_NAME=ai
DISCORD_AI_AGENT_PROCESS_ROLE=bot
OPENROUTER_CHAT_MODEL=z-ai/glm-5.2
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image
DISCORD_AGENT_RESPONSE_TIMEOUT_MS=1800000
# Optional colon-separated private overlay directories.
OVERLAY_DIRS=
CONTROL_PLANE_INTERNAL_URL=http://discord-ai-agent-api:8080
KUBERNETES_NAMESPACE=discord-ai-agent
SANDBOX_IMAGE=discord-ai-agent-sandbox:latest
SANDBOX_CACHE_DIR=/var/cache/discord-ai-agent
# Set in Kubernetes when a shared sandbox cache PVC is mounted.
SANDBOX_CACHE_PVC_NAME=
