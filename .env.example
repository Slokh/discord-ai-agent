# Required for the Discord bot.
DISCORD_TOKEN=
DISCORD_CLIENT_ID=
DISCORD_GUILD_ID=

# Required for model calls.
OPENROUTER_API_KEY=

# Required only when using GitHub PR tools.
GITHUB_TOKEN=
GITHUB_REPOSITORY=owner/discord-ai-agent

# Optional.
BOT_NAME=ai
DISCORD_AI_AGENT_PROCESS_ROLE=bot
OPENROUTER_CHAT_MODEL=deepseek/deepseek-v4-flash
OPENROUTER_CODEGEN_MODEL=z-ai/glm-5.2
OPENROUTER_EMBEDDING_MODEL=qwen/qwen3-embedding-8b
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image
CODEGEN_JOB_TIMEOUT_MINUTES=60
CODEGEN_CODEX_TIMEOUT_MINUTES=20

# Optional owner-only Railway log inspection.
RAILWAY_TOKEN=
RAILWAY_PROJECT_ID=
RAILWAY_ENVIRONMENT=production
RAILWAY_LOG_OWNER_USER_IDS=
